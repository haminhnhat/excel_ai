# Python
.venv/
__pycache__/
*.pyc

# Environment variables
.env

# Keep local upload/model folders but ignore user files
uploads/*
!uploads/.gitkeep
models/*
!models/.gitkeep
!models/README.md

# Generated outputs and logs
outputs/*
!outputs/.gitkeep
logs/*
!logs/.gitkeep

# Offline dependency cache
vendor/wheels/*
!vendor/wheels/README.md

# Excel files
*.xlsx
*.xlsm
*.xls
~$*.xlsx
~$*.xlsm
