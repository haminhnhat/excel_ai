# AI provider options:
# - mock: local rule/alias/fuzzy parser only, no API key required
# - openai: optional LLM fallback using OPENAI_API_KEY
# - ollama: optional local LLM fallback using OLLAMA_URL and OLLAMA_MODEL
AI_PROVIDER=mock

# Excel engine:
# - xlwings: best for financial models on Windows with Microsoft Excel installed
# - openpyxl: edits cells but does not calculate formulas reliably
# - auto: try xlwings, then openpyxl
EXCEL_ENGINE=xlwings

# Default workbook. Keep real Excel files local; they are ignored by .gitignore.
MODEL_PATH=models/2025.10.26_NOXH_Yen_My_BKD.xlsx

# Option A: use a model profile under config/profiles/<name>/model_map.yaml
MODEL_PROFILE=yen_my

# Option B: explicit path overrides MODEL_PROFILE if uncommented
# MODEL_MAP_PATH=config/model_map.yaml

OUTPUT_DIR=outputs
AUDIT_LOG_PATH=logs/audit_log.csv

# Optional OpenAI fallback
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# Optional Ollama/local fallback
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=qwen2.5:7b
