# AI provider options:
# - mock: local rule/alias/fuzzy parser only, no API key required
# - openai: optional LLM fallback using OPENAI_API_KEY
# - ollama: optional local LLM fallback using OLLAMA_URL and OLLAMA_MODEL
AI_PROVIDER=mock

# Excel engine:
# - xlwings: best for financial models on Windows with Microsoft Excel installed
# - openpyxl: edits cells but does not calculate formulas reliably
# - auto: try xlwings, then openpyxl
EXCEL_ENGINE=xlwings

# Excel recalc mode for xlwings:
# - calculate: fastest normal recalculation, recommended default
# - full: recalculates all open workbooks
# - full_rebuild: slowest, rebuilds dependency tree; use only for debugging/validation
# - none: skip recalculation and read current/cached values
EXCEL_RECALC_MODE=calculate

# Read-only requests with no input changes skip explicit recalculation by default.
# Set true only if users expect every "show current output" request to recalculate first.
EXCEL_RECALC_READ_ONLY=false

# Default workbook. Keep real Excel files local; they are ignored by .gitignore.
MODEL_PATH=models/2025.10.26_NOXH_Yen_My_BKD.xlsx

# Option A: use a model profile under config/profiles/<name>/model_map.yaml
MODEL_PROFILE=yen_my

# Option B: explicit path overrides MODEL_PROFILE if uncommented
# MODEL_MAP_PATH=config/model_map.yaml

OUTPUT_DIR=outputs
AUDIT_LOG_PATH=logs/audit_log.csv
ACCURACY_LOG_PATH=logs/accuracy_events.jsonl
ERROR_LOG_PATH=logs/app_errors.log
SCENARIO_RUNTIME_LOG_PATH=logs/scenario_runtime.log

# Optional OpenAI fallback
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# Optional Ollama/local fallback
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=qwen2.5:7b
