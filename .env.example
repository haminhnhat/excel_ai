# Path to the base Excel model. You can also upload a file via the web/API.
MODEL_PATH=models/2025.10.26_NOXH_Yen_My_BKD.xlsx
MODEL_MAP_PATH=config/model_map.yaml

# Recommended when Microsoft Excel is installed.
# Options: xlwings, openpyxl, auto
EXCEL_ENGINE=xlwings

# AI_PROVIDER=mock uses the built-in Vietnamese rule parser.
# AI_PROVIDER=openai calls OpenAI and expects JSON output.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OUTPUT_DIR=outputs
AUDIT_LOG_PATH=logs/audit_log.csv
